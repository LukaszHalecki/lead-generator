// Lead Generator — Schemat bazy danych Prisma
// Fundament multi-tenant SaaS dla agencji webowych

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Multi-tenancy & Auth
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrganizationMember[]
  companies   Company[]
  campaigns   Campaign[]
  importJobs  ImportJob[]
  credentials ApiCredential[]
  activities  ActivityLog[]
  notes       Note[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships OrganizationMember[]
  notes       Note[]
  activities  ActivityLog[]

  @@map("users")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model ApiCredential {
  id             String      @id @default(cuid())
  organizationId String
  provider       ApiProvider
  encryptedKey   String
  label          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@map("api_credentials")
}

enum ApiProvider {
  OUTSCRAPER
  INSTANTLY
  OPENAI
}

// ─────────────────────────────────────────────
// Companies (Leads)
// ─────────────────────────────────────────────

model Company {
  id             String @id @default(cuid())
  organizationId String

  name     String
  industry String?
  city     String?
  country  String?
  email    String?
  phone    String?
  website  String?

  websiteNormalized String?
  emailNormalized   String?

  status         CompanyStatus      @default(NEW)
  latestScore    Int?
  latestCategory AnalysisCategory?
  latestSalesOpportunity SalesOpportunity?
  latestLeadPriority     LeadPriority?

  // Denormalizacja wycen (PLN)
  latestPricingLanding     Int?
  latestPricingCompanySite Int?
  latestPricingEcommerce   Int?

  // Agregaty Instantly (per firma)
  emailDeliveredCount Int @default(0)
  emailOpenedCount    Int @default(0)
  emailClickedCount   Int @default(0)
  emailRepliedCount   Int @default(0)

  source     CompanySource @default(MANUAL)
  externalId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analyses      CompanyAnalysis[]
  campaignLeads CampaignLead[]
  messages      Message[]
  replies       Reply[]
  notes         Note[]
  activities    ActivityLog[]

  @@unique([organizationId, websiteNormalized])
  @@unique([organizationId, emailNormalized])
  @@index([organizationId, status])
  @@index([organizationId, latestScore])
  @@index([organizationId, latestSalesOpportunity])
  @@index([organizationId, latestLeadPriority])
  @@index([organizationId, industry])
  @@map("companies")
}

enum CompanyStatus {
  NEW
  ANALYZED
  TO_CONTACT
  SENT
  REPLIED
  CLIENT
}

enum CompanySource {
  MANUAL
  CSV_IMPORT
  OUTSCRAPER
}

enum AnalysisCategory {
  CRITICAL
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

enum SalesOpportunity {
  LOW
  MEDIUM
  HIGH
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

// ─────────────────────────────────────────────
// Website Analysis
// ─────────────────────────────────────────────

model CompanyAnalysis {
  id        String @id @default(cuid())
  companyId String

  // Lead Score 0-100
  score     Int
  category  AnalysisCategory
  scoreBreakdown Json? // { ssl, mobile, responsive, speed, metaTitle, ... }

  // Raport AI rozszerzony
  aiSummary       String? @db.Text
  problems        Json    // string[]
  businessImpact  Json    // string[]
  recommendations Json    // string[]
  expertSummary   String? @db.Text

  // AI sub-scores
  aiDesignScore   Int?
  aiContentScore  Int?
  aiCtaScore      Int?

  // Szansa sprzedażowa AI
  salesOpportunity       SalesOpportunity?
  salesOpportunityReason String?           @db.Text

  // Wycena projektu (PLN)
  pricingLanding     Int?
  pricingCompanySite Int?
  pricingEcommerce   Int?

  // Zrzuty ekranu (desktop + mobile)
  screenshotDesktopPath String?
  screenshotMobilePath  String?

  // Kontrole techniczne Lead Score
  hasSsl            Boolean?
  sslValidUntil     DateTime?
  isMobileFriendly  Boolean?
  isResponsive      Boolean?
  hasContactForm    Boolean?
  hasGoogleMaps     Boolean?
  hasGoogleAnalytics Boolean?
  hasGoogleTagManager Boolean?
  hasFavicon         Boolean?
  hasPrivacyPolicy   Boolean?
  hasSecurityCertificate Boolean?
  domainAgeYears     Int?
  isTechnologyModern Boolean?
  hasMetaTitle      Boolean?
  hasMetaDescription Boolean?
  hasH1             Boolean?
  metaTitle         String?
  metaDescription   String?
  h1Text            String?
  socialMedia       Json?
  loadTimeMs        Int?
  pageSpeedScore    Int?

  rawTechnicalData Json?
  rawAiResponse    Json?

  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, analyzedAt])
  @@map("company_analyses")
}

// ─────────────────────────────────────────────
// Import
// ─────────────────────────────────────────────

model ImportJob {
  id             String       @id @default(cuid())
  organizationId String
  type           ImportType
  status         ImportStatus @default(PENDING)

  params   Json?
  fileName String?

  totalRows      Int   @default(0)
  importedCount  Int   @default(0)
  duplicateCount Int   @default(0)
  errorCount     Int   @default(0)
  errors         Json?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("import_jobs")
}

enum ImportType {
  CSV
  OUTSCRAPER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// Email Campaigns (Instantly)
// ─────────────────────────────────────────────

model Campaign {
  id             String @id @default(cuid())
  organizationId String

  name   String
  status CampaignStatus @default(DRAFT)

  scoreThreshold Int?
  requireEmail   Boolean       @default(true)
  statusFilter   CompanyStatus @default(TO_CONTACT)

  instantlyCampaignId String? @unique
  instantlyStatus     String?

  leadsCount     Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  openCount      Int @default(0)
  clickCount     Int @default(0)
  replyCount     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        CampaignLead[]
  messages     Message[]

  @@index([organizationId, status])
  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model CampaignLead {
  id         String @id @default(cuid())
  campaignId String
  companyId  String

  status          CampaignLeadStatus @default(PENDING)
  instantlyLeadId String?

  addedAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([campaignId, companyId])
  @@index([campaignId, status])
  @@map("campaign_leads")
}

enum CampaignLeadStatus {
  PENDING
  ADDED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

// ─────────────────────────────────────────────
// Messages & Replies
// ─────────────────────────────────────────────

model Message {
  id         String  @id @default(cuid())
  companyId  String
  campaignId String?

  subject String
  body    String @db.Text

  generatedByAi Boolean @default(true)
  aiPromptHash  String?

  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  instantlyEmailId String?

  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  replies  Reply[]

  @@index([companyId, sentAt])
  @@index([campaignId])
  @@map("messages")
}

model Reply {
  id        String  @id @default(cuid())
  companyId String
  messageId String?

  subject   String?
  body      String  @db.Text
  fromEmail String?

  instantlyReplyId String? @unique
  receivedAt       DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([companyId, receivedAt])
  @@map("replies")
}

// ─────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────

model Note {
  id             String @id @default(cuid())
  organizationId String
  companyId      String
  authorId       String

  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("notes")
}

model ActivityLog {
  id             String  @id @default(cuid())
  organizationId String
  companyId      String?
  userId         String?

  type        ActivityType
  title       String
  description String?      @db.Text
  metadata    Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([companyId, createdAt])
  @@map("activity_logs")
}

enum ActivityType {
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
  ANALYSIS_COMPLETED
  REPORT_GENERATED
  PRICING_GENERATED
  MESSAGE_SENT
  MESSAGE_GENERATED
  REPLY_RECEIVED
  EMAIL_DELIVERED
  EMAIL_OPENED
  EMAIL_CLICKED
  NOTE_ADDED
  STATUS_CHANGED
  IMPORT_COMPLETED
  CAMPAIGN_CREATED
  LEAD_ADDED
}
